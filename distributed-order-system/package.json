{
  "name": "distributed-order-system",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "include": [
    "types/**/*.d.ts"
  ],
  "scripts": {
    "dev": "docker-compose --env-file .env.docker -f infrastructure/docker/docker-compose.yml up --build",
    "dev:infra": "docker-compose --env-file .env.docker -f infrastructure/docker/docker-compose.yml up kafka-ui pgadmin mongo-express",
    "order:local": "dotenv -e .env.local -- npx tsx watch apps/order-service/src/index.ts",
    "gateway:local": "dotenv -e .env.local -- npx tsx watch apps/api-gateway/src/index.ts",
    "prisma:gateway": "dotenv -e .env.local -- sh -c 'cd apps/api-gateway && npx prisma generate && npx prisma migrate dev'",
    "prisma:order": "dotenv -e .env.local -- sh -c 'cd apps/order-service && npx prisma generate && npx prisma migrate dev'",
    "web:build": "dotenv -e .env.local -- sh -c 'cd apps/web-client && npm run build'",
    "build": "tsc -b",
    "dev:local": "npm run prisma:gateway && npm run prisma:order && concurrently \"npm run gateway:local\" \"npm run order:local\"",
    "clean": "find . -name 'dist' -type d -exec rm -rf {} +",
    "replay:order:msg": "dotenv -e .env.local -- npx tsx apps/order-service/src/replay.ts",
    "start:all": "concurrently \"node apps/api-gateway/dist/index.js\" \"node apps/order-service/dist/index.js\" \"node apps/read-service/dist/index.js\" \"npm run preview --workspace=web-client\"",
    "proto:gen": "protoc --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=packages/proto-pack/src/generated --ts_proto_opt=outputServices=grpc-js,esModuleInterop=true,env=node --proto_path=packages/proto-pack/proto packages/proto-pack/proto/*.proto",
    "start:prod": "concurrently \"node apps/order-service/dist/index.js\" \"node apps/api-gateway/dist/index.js\"",
    "build:proto": "npm run proto:gen && tsc -b packages/proto-pack"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.4.0",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.0.0",
    "prisma": "^7.7.0",
    "protoc": "^33.5.0",
    "protoc-gen-ts": "^0.8.7",
    "rimraf": "^5.0.0",
    "ts-proto": "^2.11.4",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "mongoose": "^9.2.1",
    "pg": "^8.20.0",
    "proto-loader-gen-types": "^1.0.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  }
}
