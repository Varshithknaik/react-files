{
  "name": "distributed-order-system",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker-compose --env-file .env.docker -f infrastructure/docker/docker-compose.yml up --build",
    "dev:infra": "docker-compose --env-file .env.docker -f infrastructure/docker/docker-compose.yml up kafka zookeeper postgres-db mongo-read kafka-ui pgadmin mongo-express",
    "order:local": "dotenv -e .env.local -- npx tsx apps/order-service/src/index.ts",
    "gateway:local": "dotenv -e .env.local -- npx tsx apps/order-service/src/index.ts",
    "dev:local": "npm run order:local && npm run gateway:local",
    "build": "tsc -b",
    "clean": "find . -name 'dist' -type d -exec rm -rf {} +",
    "start:all": "concurrently \"node apps/api-gateway/dist/index.js\" \"node apps/order-service/dist/index.js\" \"node apps/read-service/dist/index.js\" \"npm run preview --workspace=web-client\""
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.16.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@types/node": "^25.3.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "kafkajs": "^2.2.4",
    "mongoose": "^9.2.1",
    "pg": "^8.18.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  }
}
