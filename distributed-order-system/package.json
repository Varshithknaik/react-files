{
  "name": "distributed-order-system",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "clean": "rimraf node_modules apps/**/dist packages/**/dist",
    "lint": "eslint . --ext .ts",
    "build": "tsc -b"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@types/node": "^25.3.0",
    "kafkajs": "^2.2.4",
    "winston": "^3.19.0"
  }
}
