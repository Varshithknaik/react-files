{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "dist",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      // "@shared/*": ["packages/shared-kernel/src/*"],
      "@core/events": ["packages/event-contracts/src/index.ts"],
      "@core/kafka": ["packages/kafka-client/src/index.ts"],
      // "@db/*": ["packages/database/src/*"],
      "@core/logger": ["packages/logger/src/index.ts"],
      // "@config/*": ["packages/config/src/*"]
      "@core/proto": ["packages/proto-pack/src/index.ts"]
    }
  }
}
