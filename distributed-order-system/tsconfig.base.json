{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "dist",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@core/events": ["packages/event-contracts/src/index.ts"],
      "@core/kafka": ["packages/kafka-client/src/index.ts"],
      "@core/logger": ["packages/logger/src/index.ts"],
      "@core/proto": ["packages/proto-pack/dist/index"]
    }
  }
}
